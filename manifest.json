{
  "manifest_version": 3,
  "name": "斗鱼鱼吧自动签到助手",
  "version": "1.0.1",
  "description": "斗鱼鱼吧一键批量自动签到工具，轻松管理关注的主播鱼吧，每日签到省时省力",
  "author": "",
  "icons": {
    "16": "icons/douyu.png",
    "32": "icons/douyu.png",
    "48": "icons/douyu.png",
    "128": "icons/douyu.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/douyu.png",
      "32": "icons/douyu.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://yuba.douyu.com/discussion/*/posts*"],
      "js": ["content.js"],
      "css": ["content.css"]
    },
    {
      "matches": ["https://yuba.douyu.com/mygroups", "https://yuba.douyu.com/groupcates/*"],
      "js": ["js/mygroups.js"],
      "css": ["content.css"]
    },
    {
      "matches": ["https://*.douyu.com/*", "https://douyu.com/*"],
      "js": ["js/auto-sign.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://*.douyu.com/*"]
}
